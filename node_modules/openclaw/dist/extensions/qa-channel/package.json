{
  "name": "@openclaw/qa-channel",
  "version": "2026.4.9",
  "private": true,
  "description": "OpenClaw QA synthetic channel plugin",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "setupEntry": "./setup-entry.js",
    "channel": {
      "id": "qa-channel",
      "label": "QA Channel",
