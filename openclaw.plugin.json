{
  "id": "odoo-dev",
  "name": "火一五·辉火云企业套件插件",
  "description": "自然语言操作辉火云企业套件（Odoo 19）、通知同步、待办管理、活动提醒",
  "version": "0.2.1",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "odoo": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "Odoo 系统地址，如 https://www.huo15.com"
          },
          "db": {
            "type": "string",
            "description": "数据库名称"
          },
          "username": {
            "type": "string",
            "description": "用户名（邮箱或登录名）"
          },
          "password": {
            "type": "string",
            "description": "密码"
          }
        },
        "required": ["url", "db", "username", "password"]
      },
      "sync": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "是否启用通知同步"
          },
          "intervalSeconds": {
            "type": "number",
            "default": 30,
            "description": "同步间隔（秒）"
          },
          "channels": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["todo", "activity", "message", "email", "calendar"]
            },
            "default": ["todo", "activity", "message"],
            "description": "同步哪些类型的通知"
          }
        }
      },
      "nlp": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "是否启用自然语言理解"
          },
          "intentPatterns": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "pattern": {
                  "type": "string",
                  "description": "正则表达式或关键词"
                },
                "intent": {
                  "type": "string",
                  "description": "意图名称"
                },
                "model": {
                  "type": "string",
                  "description": "Odoo 模型"
                },
                "action": {
                  "type": "string",
                  "description": "Odoo 方法"
                }
              }
            },
            "description": "自定义意图模式"
          }
        }
      }
    }
  }
}
